# ──────────────────────────────────────────────
# 백엔드 API 주소
#   back 레포를 docker compose up 으로 실행하면 → http://localhost:4000
#   별도 서버를 사용하면 해당 URL로 변경하세요.
# ──────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# ──────────────────────────────────────────────
# 개발용 역할 bypass
#   true  : 로그인 없이 특정 역할로 UI를 확인할 수 있습니다 (개발 전용)
#   false : 실제 로그인 흐름 사용 (기본값, 프로덕션 필수)
# ──────────────────────────────────────────────
NEXT_PUBLIC_DEV_ROLE_BYPASS=false
